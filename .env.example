# Copy this file to .env and set your real values before running the backend.
# Do not commit .env with secrets to source control.

# Dev server and backend settings
PORT=4000
VITE_BACKEND_URL=http://localhost:4000

# SMTP settings for sending inquiry emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=your-email@example.com
INQUIRY_EMAIL=vinay.official0000@gmail.com
